---
const techs = [
    { name: 'Astro', slug: 'astro' },
    { name: 'NextJS', slug: 'nextdotjs' },
    { name: 'ExpressJS', slug: 'express' },
    { name: 'TailwindCSS', slug: 'tailwindcss' },
    { name: 'React', slug: 'react' },
    { name: 'TypeScript', slug: 'typescript' },
    { name: 'Node.js', slug: 'nodedotjs' },
    { name: 'PostgreSQL', slug: 'postgresql' },
    { name: 'MongoDB', slug: 'mongodb' }
];
---

<section id="tecnologias" class="w-full px-4 py-20">
    <div class="mx-auto max-w-5xl">
        <div class="mb-12 flex items-center gap-4 sm:gap-8">
            <span class="h-px flex-1 bg-white/55"></span>
            <h2 class="text-3xl font-bold text-white sm:text-4xl">Tecnologias</h2>
            <span class="h-px flex-1 bg-white/55"></span>
        </div>

        <ul class="flex flex-wrap items-center justify-center gap-6 sm:gap-8">
            {techs.map((tech) => (
                <li>
                    <div class="group relative">
                        <button
                            type="button"
                            aria-label={tech.name}
                            class="inline-flex h-14 w-14 items-center justify-center rounded-xl border border-white/10 bg-white/5 text-white/90 transition-all duration-300 hover:-translate-y-1 hover:border-emerald-300/70 hover:bg-emerald-400/10 hover:shadow-[0_0_20px_rgba(52,211,153,0.35)]"
                        >
                            <img
                                src={`https://cdn.simpleicons.org/${tech.slug}/white`}
                                alt={tech.name}
                                loading="lazy"
                                class="h-8 w-8 opacity-95 transition-transform duration-300 group-hover:scale-110"
                            />
                        </button>

                        <span class="pointer-events-none absolute -top-12 left-1/2 -translate-x-1/2 whitespace-nowrap rounded-lg border border-white/10 bg-gray-900/95 px-3 py-1 text-sm font-medium text-white opacity-0 shadow-lg shadow-black/40 transition-all duration-300 group-hover:-translate-y-1 group-hover:opacity-100">
                            {tech.name}
                        </span>
                    </div>
                </li>
            ))}
        </ul>
    </div>
</section>