---
// Traemos la imagen por si la quieres usar en el menú móvil también
import santiImg from '../assets/santi.png';
---
<div class="fixed top-4 left-4 right-auto z-50 lg:hidden flex flex-col items-start">
  <input type="checkbox" id="btn-mobile" class="hidden" />
  
  <label for="btn-mobile" class="cursor-pointer">
      <!-- Botón Hamburguesa Estilo Píldora -->
      <div class="w-12 h-12 flex items-center justify-center bg-gray-900/80 backdrop-blur-md rounded-full border border-white/10 shadow-lg hover:bg-white/10 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
        </svg>
      </div>
      
      <!-- Menú Desplegable -->
      <nav class="opcionesMenu absolute top-14 left-0 bg-gray-900/95 backdrop-blur-3xl rounded-2xl w-48 border border-white/10 mt-3 flex flex-col items-center justify-center gap-2 py-4 shadow-xl">
        <!-- Foto en el menú móvil -->
        <img src={santiImg.src} alt="Santiago Martinez" class="w-16 h-16 rounded-full object-cover border-2 border-emerald-500/50 mb-2" />
        
        <a href="#inicio" class="w-11/12 text-center px-4 py-2 rounded-full text-white/80 hover:bg-emerald-500 hover:text-gray-900 font-medium transition-all duration-300">Inicio</a>
        <a href="#sobre-mi" class="w-11/12 text-center px-4 py-2 rounded-full text-white/80 hover:bg-emerald-500 hover:text-gray-900 font-medium transition-all duration-300">Sobre mí</a>
        <a href="#proyectos" class="w-11/12 text-center px-4 py-2 rounded-full text-white/80 hover:bg-emerald-500 hover:text-gray-900 font-medium transition-all duration-300">Proyectos</a>
        <a href="#experiencia" class="w-11/12 text-center px-4 py-2 rounded-full text-white/80 hover:bg-emerald-500 hover:text-gray-900 font-medium transition-all duration-300">Experiencia</a>
        <a href="#contacto" class="w-11/12 text-center px-4 py-2 rounded-full text-white/80 hover:bg-emerald-500 hover:text-gray-900 font-medium transition-all duration-300">Contacto</a>
      </nav>
  </label>
</div>

<style>
  /* Animaciones del menú móvil usando CSS puro parecido al que me enviaste */
  .opcionesMenu {
    opacity: 0;
    visibility: hidden;
    transform: translateY(-10px);
    transition: all 0.3s ease-in-out;
  }

  #btn-mobile:checked + label .opcionesMenu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
</style>