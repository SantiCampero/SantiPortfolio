---
const projects = [
	{
		title: 'Portfolio Interactivo',
		description: 'Sitio personal con animaciones suaves, scroll narrativo y enfoque en experiencia visual.',
		stack: ['Astro', 'Tailwind CSS', 'TypeScript'],
		repo: 'https://github.com/SantiCampero/SantiPortfolio',
		demo: 'https://santiportfolio.pages.dev/'
	},
	{
		title: 'Fudensa - Plataforma LMS',
		description: 'Plataforma LMS (Learning Management System) para la Fundación para el Desarrollo de la Enfermería y la Salud. Sistema completo de gestión de aprendizaje.',
		stack: ['React', 'TypeScript', 'PostgreSQL'],
		repo: 'https://github.com/lobohhernan/Lmsfudensa',
		demo: 'https://fudensa.pages.dev/'
	},
	{
		title: 'API de Reservas',
		description: 'Backend robusto para gestionar disponibilidad, turnos y autenticacion de usuarios.',
		stack: ['Express', 'TypeScript', 'MongoDB'],
		repo: '/coming-soon',
		demo: '/coming-soon'
	}
];
---

<section id="proyectos" class="w-full px-4 py-20">
	<div class="mx-auto w-full max-w-7xl">
		<h2 class="mb-10 text-center text-5xl font-bold text-transparent bg-linear-to-r from-white to-white/60 bg-clip-text md:text-6xl">
			PROYECTOS
		</h2>

		<div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
			{projects.map((project) => (
				<article class="group rounded-3xl border border-emerald-500/25 bg-emerald-950/10 p-6 transition-all duration-300 hover:-translate-y-1 hover:border-emerald-400/60 hover:shadow-[0_0_30px_rgba(16,185,129,0.14)]">
					<h3 class="text-2xl font-semibold text-white">{project.title}</h3>
					<p class="mt-3 text-white/75 leading-relaxed">{project.description}</p>

					<ul class="mt-5 flex flex-wrap gap-2">
						{project.stack.map((item) => (
							<li class="rounded-full border border-white/15 bg-white/5 px-3 py-1 text-sm text-white/80">
								{item}
							</li>
						))}
					</ul>

					<div class="mt-6 flex gap-3">
						<a href={project.demo} class="inline-flex h-11 items-center justify-center rounded-full border border-emerald-500/40 px-5 text-sm font-medium text-white/90 transition-colors duration-300 hover:bg-emerald-500 hover:text-emerald-950">
							Ver demo
						</a>
						<a href={project.repo} class="inline-flex h-11 items-center justify-center rounded-full border border-white/20 px-5 text-sm font-medium text-white/85 transition-colors duration-300 hover:bg-white/10 hover:text-white">
							Repositorio
						</a>
					</div>
				</article>
			))}
		</div>
	</div>
</section>
