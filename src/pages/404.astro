---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 - Página no encontrada">
	<main class="min-h-screen flex flex-col items-center justify-center px-4 text-center">
		
		<!-- 404 Number -->
		<h1 class="text-[10rem] md:text-[14rem] font-black leading-none bg-linear-to-r from-emerald-300/30 to-emerald-600/30 bg-clip-text text-transparent select-none">
			404
		</h1>

		<!-- Message -->
		<p class="text-white/80 text-xl md:text-2xl font-semibold mb-3 -mt-6">
			Página no encontrada
		</p>
		<p class="text-white/50 text-base md:text-lg max-w-md leading-relaxed mb-10">
			La página que estás buscando no existe o fue movida.
		</p>

		<!-- Back button -->
		<a href="/" class="inline-flex h-12 items-center justify-center rounded-full border border-emerald-500/40 px-8 text-base font-medium text-white/90 transition-all duration-300 hover:bg-emerald-500 hover:text-emerald-950 hover:scale-105 hover:shadow-[0_0_25px_rgba(16,185,129,0.3)]">
			<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2">
				<path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
				<polyline points="9 22 9 12 15 12 15 22"/>
			</svg>
			Volver al Inicio
		</a>

	</main>
</Layout>
